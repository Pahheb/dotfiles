### Theme

# Font
font pango:JetBrains Mono 11

# Colors
set $white1 #EDEDED
set $white2 #BFBFBF
set $black  #000000
# set $grey1  #44475A
# set $grey2  #282A36
# set $red    #FF3030
set $grey1  #505050
set $grey2  #2E2E2E
set $red    #FF1111

# Floating windows
for_window [app_id="foot-float"] floating enable

# Hide titlebar on windows
default_border pixel 2

# Window decorations
# class                 border  bground text    indicator child_border
client.focused          $white1 $white1 $black  $white1   $white1
client.focused_inactive $grey1  $grey1  $black  $grey1    $grey1
client.unfocused        $grey2  $grey2  $white2 $grey2    $grey2
client.urgent           $red    $red    $black  $red      $red
client.placeholder      $grey2  $grey2  $black  $grey2    $grey2
client.background       $black

