### Output configuration

# Start Sway with fractional scaling enabled
output eDP-1 scale 1.75

# Turn adaptive sync on for capable displays
output * adaptive_sync on

# Make frames get rendered immediately (lowers latency, increases tearing)
output * max_render_time off

# Subpixel hinting
output eDP-1 subpixel rgb

# ICC profiles
#output eDP-1 color_profile icc /home/kostya/Documents/icc/framework16_official.icm
#output eDP-1 color_profile icc /home/kostya/Documents/icc/framework16_notebookcheck.icm

# Wallpaper
#output * bg /path/to/wallpaper.png fill
output * bg #141200 solid_color

# Idle configuration
exec swayidle -w \
         timeout 180 'brightnessctl -s s 0%' resume 'brightnessctl -r' \
         timeout 240 'swaylock -f -c 141200 && swaymsg "output * power off"' \
         resume 'swaymsg "output * power on"' \
         before-sleep 'swaylock -f -c 141200'

# This will dim the screen after 180 seconds of inactivity, then lock your
# screen and turn off your displays after another 60 seconds, and turn
# your screens back on when resumed. It will also lock your screen before
# your computer goes to sleep.

# You can get the names of your outputs by running: swaymsg -t get_outputs
